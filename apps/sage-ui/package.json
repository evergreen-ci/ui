{
  "name": "sage-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:local": "env-cmd -e local pnpm build",
    "build": "tsc -b && vite build",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "eslint:fix": "pnpm eslint:strict --fix",
    "eslint:staged": "STRICT=1 eslint --concurrency=auto",
    "eslint:strict": "STRICT=1 eslint --concurrency=auto .",
    "preview": "vite preview --port 5493",
    "playwright:test": "playwright test",
    "playwright:ui": "playwright test --ui",
    "test": "vitest"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@evg-ui/lib": "workspace:*",
    "@via-ds/components": "0.0.1-canary.0",
    "@via-ds/icons": "0.0.2-canary.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@evg-ui/eslint-config": "workspace:*",
    "@evg-ui/lint-staged": "workspace:*",
    "@evg-ui/playwright-config": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "env-cmd": "10.1.0",
    "eslint": "^9.39.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
